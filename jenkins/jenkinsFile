pipeline {

    agent any

    environment {
        IMAGE_NAME = "paragkatoch/calculator:latest"
        BUILD_CONTAINER = "build"
        EMAIL = "paragkatoch@gmail.com"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Create Build Container') {
            steps {
                sh '''
                docker run -dit \
                --name $BUILD_CONTAINER \
                maven:3.9-eclipse-temurin-17 bash
                '''
            }
        }

        stage('Copy Project Into Container') {
            steps {
                sh '''
                docker cp . $BUILD_CONTAINER:/project
                '''
            }
        }

        stage('Build Project') {
            steps {
                sh '''
                docker exec $BUILD_CONTAINER \
                bash -c "cd /project && mvn clean package"
                '''
            }
        }

        stage('Run Tests') {
            steps {
                sh '''
                docker exec $BUILD_CONTAINER \
                bash -c "cd /project && mvn test"
                '''
            }
        }

        stage('Create Image') {
            steps {
                sh '''
                docker build -t $IMAGE_NAME -f ./docker/dockerfile .
                '''
            }
        }

        stage('Push Image to DockerHub') {
            steps {
                script {
                     docker.withRegistry('', 'DockerHubCred') {
                         sh "docker push $IMAGE_NAME"
                     }
                }
            }
        }

        stage('Deploy with Ansible') {
            steps {
                sh '''
                ansible-playbook ansible/playbook.yml -i ansible/inventory
                '''
            }
        }
    }
   
    post {

        always {
            sh "docker rm -f $BUILD_CONTAINER || true"
        }

        success {
            mail(
                subject: "Build SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
                Build completed successfully.

                Job: ${env.JOB_NAME}
                Build Number: ${env.BUILD_NUMBER}

                View build details:
                ${env.BUILD_URL}
                """,
                to: "${env.EMAIL}"
            )
        }

        failure {
            mail(
                subject: "Build FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
                The CI/CD pipeline failed.

                Job: ${env.JOB_NAME}
                Build Number: ${env.BUILD_NUMBER}
 
                Check the full logs here:
                ${env.BUILD_URL}
                """,
                to: "${env.EMAIL}"
            )
        }
    }
}
