pipeline {

    agent any

    environment {
        IMAGE_NAME = "paragkatoch/calculator:latest"
        BUILD_CONTAINER = "build"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Create Build Container') {
            steps {
                sh '''
                docker run -dit \
                --name $BUILD_CONTAINER \
                maven:3.9-eclipse-temurin-17 bash
                '''
            }
        }

        stage('Copy Project Into Container') {
            steps {
                sh '''
                docker cp . $BUILD_CONTAINER:/project
                '''
            }
        }

        stage('Build Project') {
            steps {
                sh '''
                docker exec $BUILD_CONTAINER \
                bash -c "cd /project && mvn clean package"
                '''
            }
        }

        stage('Run Tests') {
            steps {
                sh '''
                docker exec $BUILD_CONTAINER \
                bash -c "cd /project && mvn test"
                '''
            }
        }

        stage('Create Image') {
            steps {
                sh '''
                docker build -t $IMAGE_NAME -f ./docker/dockerfile .
                '''
            }
        }

        stage('Push Image to DockerHub') {
            steps {
                script {
                     docker.withRegistry('', 'DockerHubCred') {
                         sh "docker push $IMAGE_NAME"
                     }
                }
            }
        }

        stage('Deploy with Ansible') {
            steps {
                sh '''
                ansible-playbook ansible/playbook.yml -i ansible/inventory
                '''
            }
        }
    }
   
    post {

        success {
            sh 'docker rm -f $BUILD_CONTAINER || true'
        }

        failure {
            sh 'docker rm -f $BUILD_CONTAINER || true'
        }
    }
}
