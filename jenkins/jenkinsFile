pipeline {

    agent any

    environment {
        IMAGE_NAME = "paragkatoch/calculator:latest"
        EMAIL = "paragkatoch@gmail.com"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Create Image') {
            steps {
                sh '''
                docker build -t $IMAGE_NAME -f ./docker/dockerfile .
                '''
            }
        }

        stage('Push Image to DockerHub') {
            steps {
                script {
                     docker.withRegistry('', 'DockerHubCred') {
                         sh "docker push $IMAGE_NAME"
                     }
                }
            }
        }

        stage('Deploy with Ansible') {
            steps {
                sh '''
                ansible-playbook ansible/playbook.yml -i ansible/inventory
                '''
            }
        }
    }
   
    post {

	    success {
       		 emailext(
	            to: "${env.EMAIL}",
        	    subject: "Build SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
	            mimeType: 'text/html',
        	    body: """
			<h3 style="color:green;">Build Successful</h3>

			<b>Job:</b> ${env.JOB_NAME}<br>
			<b>Build:</b> ${env.BUILD_NUMBER}<br>
			<b>Branch:</b> ${env.GIT_BRANCH}<br>

			<br>
			<b>Results:</b><br>
			<a href="${env.BUILD_URL}">${env.BUILD_URL}</a>
			""",
		    attachLog: true
       		 )
    	    }

	    failure {
        	emailext(
         	    to: "${env.EMAIL}",
	            subject: "Build FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
        	    mimeType: 'text/html',
	            body: """
			<h3 style="color:red;">Build Failed</h3>

			<b>Job:</b> ${env.JOB_NAME}<br>
			<b>Build:</b> ${env.BUILD_NUMBER}<br>
			<b>Branch:</b> ${env.GIT_BRANCH}<br>

			<br>
			<b>Check logs:</b><br>
			<a href="${env.BUILD_URL}console">${env.BUILD_URL}console</a>
			""",
	            attachLog: true
       		 )
	   }
	}
}
